# ============================================
# ANTI AI Financial Analysis — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Optional: Builder.io public key (not a secret)
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__

# Ping message for health check endpoint
PING_MESSAGE="ping pong"

# ============================================
# SERVER-SIDE ONLY — Supabase Configuration
# ============================================
# These must NOT use the VITE_ prefix (that would expose them to the frontend).
# On Vercel/Netlify, set these in the platform's Environment Variables dashboard.

SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
